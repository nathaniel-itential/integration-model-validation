#!/usr/bin/env bash
# validate-integration: end-to-end OpenAPI spec validation against an Itential dev stack.
#
# Usage:
#   validate-integration <spec.json> [--cleanup] [--group <name>] [--json]
#   validate-integration fetch [--branch <name>]
#   validate-integration bulk  [--no-cleanup] [--throttle <s>] [--group <name>]
#   validate-integration platform-reset
#
# Exit codes:
#   0 = PASS (single) or no failures (bulk/fetch)
#   1 = at least one spec FAILed or was PARTIAL
#   2 = setup error (bad args, missing config, login failed, dev stack unreachable)

set -uo pipefail

CONFIG_DIR="$HOME/.claude/skills/validate-integration"
CONFIG_FILE="$CONFIG_DIR/config.json"
PATHS_FILE="$PWD/validate-paths.json"
REPORT_FILE="$PWD/validate-report.json"
DEFAULT_ASSETS_CACHE="$HOME/.cache/itential-assets"
DEFAULT_ASSETS_REPO_URL="https://github.com/itential/assets.git"
DEFAULT_ASSETS_BRANCH="add-openapi-specs"

usage() {
  cat >&2 <<'EOF'
Usage:
  validate-integration <spec.json> [--cleanup] [--group <name>] [--json]
  validate-integration fetch [--branch <name>]
  validate-integration bulk  [--no-cleanup] [--throttle <s>] [--group <name>]
  validate-integration platform-reset

Run 'validate-integration help' for examples and flag details.
EOF
  exit 2
}

print_help() {
  cat <<'EOF'
USAGE
  validate-integration <spec.json> [flags]    # validate one spec
  validate-integration fetch [--branch <name>] # pull specs from the assets repo
  validate-integration bulk [flags]            # validate every spec from fetch
  validate-integration platform-reset          # restart the platform container
  validate-integration help                    # this screen

FLAGS
  Single-spec mode:
    --cleanup         Delete the imported model + instance after the run
    --group <name>    Grant the role to this group (default: from config)
    --json            Emit JSON instead of the formatted report

  fetch:
    --branch <name>   Use a non-default branch of the assets repo

  bulk:
    --no-cleanup      Keep imported models + instances after each spec
                      (cleanup is ON by default in bulk)
    --throttle <s>    Seconds to pause between specs (default: 0). Bump
                      to 1–3 if the platform starts returning HTTP 404 or
                      000 on import mid-run.
    --group <name>    Group override for all specs in the batch

    Bulk reads paths from validate-paths.json (written by 'fetch') in the current
    working directory and writes results to validate-report.json in the same directory.

  platform-reset:
    (no flags)        Runs 'docker restart <platform_container>' and waits up
                      to 120s for the dev stack to become healthy again.

STAGES (per spec)
  login           authenticate against the dev stack
  auth-check      verify spec's components.securitySchemes only uses
                  supported types AND that at least one scheme is applied
                  to operations. Fails fast before touching the platform.
  import          POST the spec; canonical AJV validation
  instance        create a virtual instance from the model
  role-discovery  find the auto-created admin role for the versionId
  authz           grant the role to the configured group
  methods         verify role.allowedMethods.length == operation count
  cleanup         (optional) delete instance + model, verify gone

EXIT CODES
  0   PASS (single) or no failures (bulk/fetch)
  1   at least one spec FAILed or was PARTIAL
  2   setup error (bad args, missing config, login failed, stack unreachable)
EOF
}

# --------- bootstrap config ---------
if [ ! -f "$CONFIG_FILE" ]; then
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
{
  "iap_url": "http://localhost:3000",
  "username": "admin@itential",
  "password": "admin",
  "default_group": "admin_group",
  "download_path": "$HOME/Downloads",
  "assets_repo_url": "$DEFAULT_ASSETS_REPO_URL",
  "assets_branch": "$DEFAULT_ASSETS_BRANCH",
  "assets_cache_dir": "$DEFAULT_ASSETS_CACHE",
  "platform_container": "platform"
}
EOF
  chmod 600 "$CONFIG_FILE"
  echo "Created default config at $CONFIG_FILE" >&2
fi

IAP_URL=$(node -e "console.log(require('$CONFIG_FILE').iap_url || '')")
USERNAME=$(node -e "console.log(require('$CONFIG_FILE').username || '')")
PASSWORD=$(node -e "console.log(require('$CONFIG_FILE').password || '')")
DEFAULT_GROUP=$(node -e "console.log(require('$CONFIG_FILE').default_group || '')")
DOWNLOAD_PATH=$(node -e "const c=require('$CONFIG_FILE'); console.log((c.download_path||'').replace(/^~/, process.env.HOME))")
ASSETS_REPO_URL=$(node -e "console.log(require('$CONFIG_FILE').assets_repo_url || '$DEFAULT_ASSETS_REPO_URL')")
ASSETS_BRANCH=$(node -e "console.log(require('$CONFIG_FILE').assets_branch || '$DEFAULT_ASSETS_BRANCH')")
ASSETS_CACHE_DIR=$(node -e "const c=require('$CONFIG_FILE'); console.log(((c.assets_cache_dir||'$DEFAULT_ASSETS_CACHE')).replace(/^~/, process.env.HOME))")
PLATFORM_CONTAINER=$(node -e "console.log(require('$CONFIG_FILE').platform_container || 'platform')")

# Find the auto-created admin role for a given integration-model versionId.
# Sorts using Mongo's _id so pages are stable if roles are added mid-scan.
_scan_for_admin_role() {
  local local_token="$1" version="$2"
  local skip page found_id got empty_pages=0
  for skip in $(seq 0 100 10000); do
    page=$(curl -s -H "Cookie: token=$local_token" "$IAP_URL/authorization/roles?sort=_id&order=1&limit=100&skip=$skip")
    found_id=$(echo "$page" | node -e "
try {
  const r=JSON.parse(require('fs').readFileSync(0,'utf-8'));
  const role=(r.results||[]).find(x=>x.provenance===process.argv[1] && x.name==='admin');
  process.stdout.write(role?._id||'');
} catch(e) {}
" -- "$version")
    if [ -n "$found_id" ]; then
      echo "$found_id"
      return 0
    fi
    got=$(echo "$page" | node -e "try {const r=JSON.parse(require('fs').readFileSync(0,'utf-8'));process.stdout.write(String((r.results||[]).length));}catch(e){process.stdout.write('0');}")
    if [ "$got" -eq 0 ]; then
      empty_pages=$((empty_pages + 1))
      [ "$empty_pages" -ge 2 ] && break
    else
      empty_pages=0
    fi
  done
  return 1
}


find_admin_role_id() {
  local local_token="$1" version="$2"
  local attempt result
  for attempt in 1 2 3; do
    result=$(_scan_for_admin_role "$local_token" "$version")
    if [ -n "$result" ]; then
      echo "$result"
      return 0
    fi
    [ "$attempt" -lt 3 ] && sleep 1
  done
  return 1
}

# DELETEs the instance + integration model, then verifies the model is gone
# by polling the single-model endpoint until it stops returning 200.
#
# Returns 0 if the model is verifiably gone, 1 if it's still present after
# the timeout (1.5s).
cleanup_one() {
  local local_token="$1" inst="$2" version="$3"
  # Delete instance first — instances reference the model and block its deletion.
  curl -s -o /dev/null -X DELETE "$IAP_URL/integrations/$inst" -H "Cookie: token=$local_token"
  local enc
  enc=$(node -e "console.log(encodeURIComponent(process.argv[1]))" -- "$version")
  curl -s -o /dev/null -X DELETE "$IAP_URL/integration-models/$enc" -H "Cookie: token=$local_token"
  local i code
  for i in 1 2 3 4 5 6; do
    code=$(curl -s -o /dev/null -w "%{http_code}" -H "Cookie: token=$local_token" "$IAP_URL/integration-models/$enc")
    [ "$code" != "200" ] && return 0
    sleep 0.25
  done
  return 1
}

# --------- per-spec pipeline ---------
# Inputs: $1 = absolute spec path, $2 = token
# Optional env: GROUP_NAME, CLEANUP, JSON_OUT
# Sets globals: SPEC_VERDICT, SPEC_VERSION_ID, SPEC_EXPECTED_OPS, SPEC_ACTUAL_METHODS,
#               SPEC_STAGES_JSON, SPEC_FAIL_STAGE, SPEC_FAIL_DETAIL
validate_one_spec() {
  local spec_path="$1" token="$2"
  SPEC_VERDICT=""
  SPEC_FAIL_STAGE=""
  SPEC_FAIL_DETAIL=""
  SPEC_ACTUAL_METHODS=""
  local stages_json="[]"
  local imported=false
  local record_local

  record_local() {
    local name="$1" ok="$2" detail="$3"
    stages_json=$(node -e "
const s=$stages_json;
s.push({name:'$name', ok:$ok, detail:process.argv[1]});
console.log(JSON.stringify(s));
" -- "$detail")
  }

  # Parse spec metadata
  local title version
  if ! title=$(node -e "console.log(require('$spec_path').info.title)" 2>/dev/null); then
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="parse"
    SPEC_FAIL_DETAIL="could not parse spec JSON"
    SPEC_STAGES_JSON='[{"name":"parse","ok":false,"detail":"could not parse spec JSON"}]'
    return 1
  fi
  version=$(node -e "console.log(require('$spec_path').info.version||'')")
  SPEC_VERSION_ID="$title:$version"
  SPEC_EXPECTED_OPS=$(node -e "
const s=require('$spec_path');
const verbs=['get','post','put','patch','delete','head','options'];
let n=0;
for(const p of Object.values(s.paths||{})) for(const v of Object.keys(p)) if(verbs.includes(v)) n++;
console.log(n);
")
  local instance_name
  instance_name=$(echo "$title" | tr '[:upper:] ' '[:lower:]-' | tr -cd '[:alnum:]-')

  # Step 0.5: auth check
  # Verify the spec's components.securitySchemes only uses types Itential
  # supports (apiKey, http with basic/bearer, oauth2, mutualTLS, openIdConnect)
  # AND that at least one supported scheme is applied to operations.
  local auth_result
  auth_result=$(node -e "
const s=require('$spec_path');
const schemes=(s.components||{}).securitySchemes||{};
const entries=Object.entries(schemes);
if (entries.length===0) { console.log('OK|no security schemes defined'); process.exit(0); }
const SUPPORTED=new Set(['apikey','http','oauth2','mutualtls','openidconnect']);
const HTTP_OK=new Set(['basic','bearer']);
const bad=[];
const summary=[];
const supported=[];
for (const [name, sc] of entries) {
  const t=(sc.type||'').toLowerCase();
  if (!SUPPORTED.has(t)) {
    bad.push(\`'\${name}' uses unsupported type '\${sc.type||'(missing)'}'\`);
    continue;
  }
  if (t==='http') {
    const sub=(sc.scheme||'').toLowerCase();
    if (!HTTP_OK.has(sub)) {
      bad.push(\`'\${name}' is http but uses unsupported scheme '\${sc.scheme||'(missing)'}'\`);
      continue;
    }
    summary.push(\`\${name}:http/\${sub}\`);
    supported.push({name, display:\`http/\${sub}\`});
  } else {
    summary.push(\`\${name}:\${sc.type}\`);
    supported.push({name, display:sc.type});
  }
}
if (bad.length) { console.log('FAIL|'+bad.join('; ')); process.exit(0); }
const applied=new Set();
for (const req of (s.security||[])) for (const k of Object.keys(req)) applied.add(k);
const verbs=new Set(['get','post','put','patch','delete','head','options']);
for (const item of Object.values(s.paths||{})) {
  for (const [v,op] of Object.entries(item)) {
    if (!verbs.has(v)||!op||typeof op!=='object') continue;
    for (const req of (op.security||[])) for (const k of Object.keys(req)) applied.add(k);
  }
}
const unapplied=supported.filter(({name})=>!applied.has(name));
const parts=[summary.join(', ')];
for (const {name,display} of unapplied) parts.push(\`auth defined but unapplied: '\${name}' (\${display})\`);
const status=unapplied.length===supported.length&&supported.length>0 ? 'FAIL' : 'OK';
console.log(status+'|'+parts.join('; '));
")
  local auth_status="${auth_result%%|*}" auth_detail="${auth_result#*|}"
  if [ "$auth_status" = "FAIL" ]; then
    record_local "auth-check" "false" "$auth_detail"
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="auth-check"
    SPEC_FAIL_DETAIL="$auth_detail"
    SPEC_STAGES_JSON="$stages_json"
    return 1
  fi
  record_local "auth-check" "true" "$auth_detail"

  # Step 1: import into platform
  local tmp_body
  tmp_body=$(mktemp -t iap-import-body.XXXXXX)
  node -e "require('fs').writeFileSync('$tmp_body', JSON.stringify({model: require('$spec_path')}))"
  local import_full import_code import_body
  import_full=$(curl -s -w "\nHTTPCODE:%{http_code}" -X POST "$IAP_URL/integration-models" \
    -H "Cookie: token=$token" \
    -H "Content-Type: application/json" \
    --data @"$tmp_body")
  import_code=$(echo "$import_full" | tail -n1 | sed 's/HTTPCODE://')
  import_body=$(echo "$import_full" | sed '$d')
  rm -f "$tmp_body"

  if [ "$import_code" = "500" ] && echo "$import_body" | grep -q "already exists"; then
    record_local "import" "true" "HTTP 500 (already imported, treating as pass)"
    imported=true
  elif [ "$import_code" -ge 200 ] && [ "$import_code" -lt 300 ]; then
    record_local "import" "true" "HTTP $import_code"
    imported=true
  else
    local err_summary
    err_summary=$(echo "$import_body" | node -e "
try {
  const b=JSON.parse(require('fs').readFileSync(0,'utf-8'));
  if (Array.isArray(b) && b.length) {
    console.log('first AJV error: ' + (b[0].instancePath||'(root)') + ' ' + (b[0].message||''));
  } else if (typeof b === 'string') { console.log(b); }
  else { console.log(JSON.stringify(b).slice(0,200)); }
} catch(e) { console.log(require('fs').readFileSync(0,'utf-8').slice(0,200)); }
")
    record_local "import" "false" "HTTP $import_code: $err_summary"
    SPEC_STAGES_JSON="$stages_json"
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="import"
    SPEC_FAIL_DETAIL="HTTP $import_code: $err_summary"
    return 1
  fi

  # Step 2: create instance
  local instance_req_file instance_full instance_code instance_body
  instance_req_file=$(mktemp -t iap-instance-body.XXXXXX)
  node -e "
const name=process.argv[1], vid=process.argv[2];
process.stdout.write(JSON.stringify({properties:{name,type:'Adapter',properties:{id:name,type:vid},virtual:true}}));
" -- "$instance_name" "$SPEC_VERSION_ID" > "$instance_req_file"
  instance_full=$(curl -s -w "\nHTTPCODE:%{http_code}" -X POST "$IAP_URL/integrations" \
    -H "Cookie: token=$token" \
    -H "Content-Type: application/json" \
    --data @"$instance_req_file")
  instance_code=$(echo "$instance_full" | tail -n1 | sed 's/HTTPCODE://')
  instance_body=$(echo "$instance_full" | sed '$d')
  rm -f "$instance_req_file"

  # update name with name from POST to ensure proper deletion
  if [ "$instance_code" -ge 200 ] && [ "$instance_code" -lt 300 ]; then
    local actual_name
    actual_name=$(echo "$instance_body" | node -e "
try {
  const b=JSON.parse(require('fs').readFileSync(0,'utf-8'));
  const d=b.data||b;
  process.stdout.write(d.name||(d.properties&&d.properties.name)||(d.properties&&d.properties.id)||'');
} catch(e) {}
")
    if [ -n "$actual_name" ] && [ "$actual_name" != "$instance_name" ]; then
      instance_name="$actual_name"
    fi
    record_local "instance" "true" "HTTP $instance_code (created, name=$instance_name)"
  elif echo "$instance_body" | grep -Eqi "already exists|duplicate"; then
    record_local "instance" "true" "HTTP $instance_code (already exists)"
  else
    record_local "instance" "false" "HTTP $instance_code: ${instance_body:0:120}"
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="instance"
    SPEC_FAIL_DETAIL="HTTP $instance_code: ${instance_body:0:120}"
    if $imported && [ "${CLEANUP:-false}" = "true" ]; then
      if cleanup_one "$token" "$instance_name" "$SPEC_VERSION_ID"; then
        record_local "cleanup" "true" "deleted model (on instance failure)"
      else
        record_local "cleanup" "false" "DELETE issued but model still present after 1.5s"
      fi
    fi
    SPEC_STAGES_JSON="$stages_json"
    return 1
  fi

  # Step 3: role discovery
  local role_id
  role_id=$(find_admin_role_id "$token" "$SPEC_VERSION_ID")
  if [ -z "$role_id" ]; then
    record_local "role-discovery" "false" "no admin role with provenance=$SPEC_VERSION_ID"
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="role-discovery"
    SPEC_FAIL_DETAIL="no admin role with provenance=$SPEC_VERSION_ID"
    if $imported && [ "${CLEANUP:-false}" = "true" ]; then
      if cleanup_one "$token" "$instance_name" "$SPEC_VERSION_ID"; then
        record_local "cleanup" "true" "deleted model + instance (on role-discovery failure)"
      else
        record_local "cleanup" "false" "DELETE issued but model still present after 1.5s"
      fi
    fi
    SPEC_STAGES_JSON="$stages_json"
    return 1
  fi
  record_local "role-discovery" "true" "role_id=$role_id"

  # Step 4: authz
  local all_groups group_id
  all_groups=$(curl -s -H "Cookie: token=$token" "$IAP_URL/authorization/groups?limit=200")
  group_id=$(echo "$all_groups" | node -e "
const r=JSON.parse(require('fs').readFileSync(0,'utf-8'));
const g=(r.results||[]).find(x=>x.name===process.argv[1]);
console.log(g?._id||'');
" -- "$GROUP_NAME")
  if [ -z "$group_id" ]; then
    local available
    available=$(echo "$all_groups" | node -e "
const r=JSON.parse(require('fs').readFileSync(0,'utf-8'));
console.log((r.results||[]).map(g=>g.name).join(', '));
")
    record_local "authz" "false" "group '$GROUP_NAME' not found. Available: $available"
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="authz"
    SPEC_FAIL_DETAIL="group '$GROUP_NAME' not found"
    if $imported && [ "${CLEANUP:-false}" = "true" ]; then
      if cleanup_one "$token" "$instance_name" "$SPEC_VERSION_ID"; then
        record_local "cleanup" "true" "deleted model + instance (on authz failure)"
      else
        record_local "cleanup" "false" "DELETE issued but model still present after 1.5s"
      fi
    fi
    SPEC_STAGES_JSON="$stages_json"
    return 1
  fi

  local current already
  current=$(curl -s -H "Cookie: token=$token" "$IAP_URL/authorization/groups/$group_id" \
    | node -e "const g=JSON.parse(require('fs').readFileSync(0,'utf-8'));console.log(JSON.stringify(g.assignedRoles||[]))")
  already=$(node -e "console.log($current.some(r=>r.roleId==='$role_id') ? 'yes' : 'no')")

  if [ "$already" = "yes" ]; then
    record_local "authz" "true" "group=$GROUP_NAME (role already attached)"
  else
    local new_roles patch_code
    new_roles=$(node -e "
const cur=$current;
cur.push({roleId:'$role_id'});
console.log(JSON.stringify(cur));
")
    patch_code=$(curl -s -o /dev/null -w "%{http_code}" -X PATCH "$IAP_URL/authorization/groups/$group_id" \
      -H "Cookie: token=$token" \
      -H "Content-Type: application/json" \
      -d "{\"updates\": {\"assignedRoles\": $new_roles}}")
    if [ "$patch_code" -ge 200 ] && [ "$patch_code" -lt 300 ]; then
      record_local "authz" "true" "group=$GROUP_NAME, HTTP $patch_code (newly granted)"
    else
      record_local "authz" "false" "group=$GROUP_NAME, HTTP $patch_code"
      SPEC_VERDICT="FAIL"
      SPEC_FAIL_STAGE="authz"
      SPEC_FAIL_DETAIL="group=$GROUP_NAME, HTTP $patch_code"
      if $imported && [ "${CLEANUP:-false}" = "true" ]; then
        if cleanup_one "$token" "$instance_name" "$SPEC_VERSION_ID"; then
          record_local "cleanup" "true" "deleted model + instance (on authz patch failure)"
        else
          record_local "cleanup" "false" "DELETE issued but model still present after 1.5s"
        fi
      fi
      SPEC_STAGES_JSON="$stages_json"
      return 1
    fi
  fi

  # Step 5: methods
  SPEC_ACTUAL_METHODS=$(curl -s -H "Cookie: token=$token" "$IAP_URL/authorization/roles/$role_id" \
    | node -e "
const r=JSON.parse(require('fs').readFileSync(0,'utf-8'));
const role=r.result||r;
console.log((role.allowedMethods||[]).length);
")
  if [ "$SPEC_ACTUAL_METHODS" = "$SPEC_EXPECTED_OPS" ]; then
    record_local "methods" "true" "$SPEC_ACTUAL_METHODS/$SPEC_EXPECTED_OPS"
    SPEC_VERDICT="PASS"
  elif [ "$SPEC_ACTUAL_METHODS" = "0" ]; then
    record_local "methods" "false" "0/$SPEC_EXPECTED_OPS (no methods on role - check role discovery filter)"
    SPEC_VERDICT="FAIL"
    SPEC_FAIL_STAGE="methods"
    SPEC_FAIL_DETAIL="0/$SPEC_EXPECTED_OPS"
  else
    record_local "methods" "false" "$SPEC_ACTUAL_METHODS/$SPEC_EXPECTED_OPS (some operations dropped during import - usually duplicate/missing operationIds)"
    SPEC_VERDICT="PARTIAL"
    SPEC_FAIL_STAGE="methods"
    SPEC_FAIL_DETAIL="$SPEC_ACTUAL_METHODS/$SPEC_EXPECTED_OPS"
  fi

  # Step 6: optional cleanup
  if [ "${CLEANUP:-false}" = "true" ]; then
    if cleanup_one "$token" "$instance_name" "$SPEC_VERSION_ID"; then
      record_local "cleanup" "true" "deleted instance + model (verified)"
    else
      record_local "cleanup" "false" "DELETE issued but model still present after 1.5s"
    fi
  fi

  SPEC_STAGES_JSON="$stages_json"
  return 0
}

# --------- report helpers ---------
emit_full_report() {
  local spec_path="$1" login_json="$2"
  local stages
  stages=$(node -e "
const login=JSON.parse(process.argv[1]);
const rest=JSON.parse(process.argv[2]);
console.log(JSON.stringify([login, ...rest]));
" -- "$login_json" "$SPEC_STAGES_JSON")
  if [ "${JSON_OUT:-false}" = "true" ]; then
    node -e "
console.log(JSON.stringify({
  spec: process.argv[1],
  versionId: process.argv[2],
  expectedOps: parseInt(process.argv[3], 10),
  actualMethods: process.argv[4] ? parseInt(process.argv[4], 10) : null,
  verdict: process.argv[5],
  stages: JSON.parse(process.argv[6])
}, null, 2));
" -- "$spec_path" "$SPEC_VERSION_ID" "$SPEC_EXPECTED_OPS" "${SPEC_ACTUAL_METHODS:-}" "$SPEC_VERDICT" "$stages"
  else
    echo "=== Integration Validation Report ==="
    echo "Spec:          $spec_path"
    echo "VersionId:     $SPEC_VERSION_ID"
    echo "Expected ops:  $SPEC_EXPECTED_OPS"
    echo "Verdict:       $SPEC_VERDICT"
    echo ""
    echo "Stage breakdown:"
    node -e "
const s=JSON.parse(process.argv[1]);
for (const x of s) {
  const mark = x.ok ? '✓' : '✗';
  console.log('  [' + mark + '] ' + x.name.padEnd(16) + x.detail);
}
" -- "$stages"
  fi
}

verdict_mark() {
  case "$1" in
    PASS)    echo "✓" ;;
    PARTIAL) echo "~" ;;
    *)       echo "✗" ;;
  esac
}

write_report_md() {
  local md_file="${REPORT_FILE%.json}.md"
  node -e "
const report=JSON.parse(require('fs').readFileSync(process.argv[1],'utf-8'));
const s=report.summary;
const SKIP=new Set(['assets','itential-assets']);
function label(spec,vid){
  const parts=(spec||'').split('/');
  const idx=parts.lastIndexOf('OpenAPIs');
  const file=parts[parts.length-1]||'—';
  let product='—';
  if(idx>0){
    const vp=[];
    for(let i=idx-1;i>=0&&vp.length<2;i--){
      if(!SKIP.has(parts[i]))vp.unshift(parts[i]);
      else break;
    }
    product=vp.join(' / ')||parts[idx-1];
  }
  const title=vid?vid.split(':').slice(0,-1).join(':'):file;
  return {product,title};
}
function esc(s){return String(s).replace(/\|/g,'\\|');}
const lines=[];
lines.push('# Integration Validation Report');
lines.push('');
lines.push('**Date:** '+report.timestamp+'  ');
if(report.aborted){
  lines.push('**Status:** Aborted  ');
  lines.push('**Progress:** '+s.validated+' of '+s.total+' specs validated  ');
} else {
  lines.push('**Status:** Complete  ');
}
lines.push('**Results:** '+s.pass+' PASS · '+s.partial+' PARTIAL · '+s.fail+' FAIL');
lines.push('');
lines.push('## Results');
lines.push('');
lines.push('| Product | Spec | Result |');
lines.push('|---------|------|--------|');
for(const r of report.results){
  const {product,title}=label(r.spec,r.versionId);
  let result;
  if(r.verdict==='PASS') result='✓ PASS ('+r.actualMethods+'/'+r.expectedOps+')';
  else if(r.verdict==='PARTIAL') result='~ PARTIAL ('+r.actualMethods+'/'+r.expectedOps+')';
  else result='✗ FAIL';
  lines.push('| '+esc(product)+' | '+esc(title)+' | '+result+' |');
}
const failures=report.results.filter(r=>r.verdict!=='PASS');
if(failures.length>0){
  lines.push('');
  lines.push('## Failures');
  for(const r of failures){
    const {product,title}=label(r.spec,r.versionId);
    lines.push('');
    lines.push('### '+esc(product)+' — '+esc(title));
    if(r.verdict==='PARTIAL'){
      lines.push('**Result:** PARTIAL — '+r.actualMethods+' of '+r.expectedOps+' operations callable');
    } else {
      lines.push('**Stage:** '+(r.failStage||'—')+'  ');
      lines.push('**Detail:** '+(r.failDetail||'—'));
    }
  }
}
lines.push('');
require('fs').writeFileSync(process.argv[2],lines.join('\n'));
" -- "$REPORT_FILE" "$md_file"
  echo "Markdown report written to $md_file"
}

# --------- login ---------
do_login() {
  local token sanity
  token=$(curl -s --max-time 10 -X POST "$IAP_URL/login" \
    -H "Content-Type: application/json" \
    -d "{\"user\": {\"username\": \"$USERNAME\", \"password\": \"$PASSWORD\"}}")
  sanity=$(curl -s --max-time 10 -o /dev/null -w "%{http_code}" \
    -H "Cookie: token=$token" \
    "$IAP_URL/authorization/accounts?limit=1")
  if [ "$sanity" != "200" ]; then
    LOGIN_TOKEN=""
    LOGIN_STAGE_JSON=$(node -e "console.log(JSON.stringify({name:'login', ok:false, detail:'sanity ping HTTP $sanity, login body: '+process.argv[1].slice(0,120)}))" -- "$token")
    return 1
  fi
  LOGIN_TOKEN="$token"
  LOGIN_STAGE_JSON='{"name":"login","ok":true,"detail":"sanity ping HTTP 200"}'
  return 0
}

platform_health() {
  local local_token="$1"
  local code
  code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 \
    -H "Cookie: token=$local_token" \
    "$IAP_URL/authorization/accounts?limit=1")
  [ "$code" = "200" ]
}

# --------- subcommands ---------

#Single validation with a direct path to the json
cmd_single() {
  local spec_path="" group_override="" cleanup=false json_out=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --cleanup) cleanup=true; shift ;;
      --group)   group_override="${2:-}"; shift 2 ;;
      --json)    json_out=true; shift ;;
      -h|--help) usage ;;
      -*)        echo "Unknown flag: $1" >&2; usage ;;
      *)         if [ -z "$spec_path" ]; then spec_path="$1"; else usage; fi; shift ;;
    esac
  done
  [ -n "$spec_path" ] || usage

  if [ ! -f "$spec_path" ] && [ -n "$DOWNLOAD_PATH" ] && [ -f "$DOWNLOAD_PATH/$spec_path" ]; then
    spec_path="$DOWNLOAD_PATH/$spec_path"
  fi
  if [ ! -f "$spec_path" ]; then
    echo "Spec file not found: $spec_path" >&2
    [ -n "$DOWNLOAD_PATH" ] && echo "  also tried: $DOWNLOAD_PATH/$spec_path" >&2
    exit 2
  fi
  spec_path=$(cd "$(dirname "$spec_path")" && pwd)/$(basename "$spec_path")

  GROUP_NAME="${group_override:-$DEFAULT_GROUP}"
  CLEANUP="$cleanup"
  JSON_OUT="$json_out"

  if ! do_login; then
    if $JSON_OUT; then
      node -e "
console.log(JSON.stringify({
  spec: process.argv[1],
  verdict: 'FAIL',
  stages: [JSON.parse(process.argv[2])]
}, null, 2));
" -- "$spec_path" "$LOGIN_STAGE_JSON"
    else
      echo "=== Integration Validation Report ==="
      echo "Spec:          $spec_path"
      echo "Verdict:       FAIL"
      echo ""
      echo "Stage breakdown:"
      node -e "const x=JSON.parse(process.argv[1]); console.log('  [✗] login           '+x.detail);" -- "$LOGIN_STAGE_JSON"
    fi
    exit 2
  fi

  validate_one_spec "$spec_path" "$LOGIN_TOKEN"
  emit_full_report "$spec_path" "$LOGIN_STAGE_JSON"

  local timestamp pass=0 fail=0 partial=0
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  case "$SPEC_VERDICT" in
    PASS)    pass=1 ;;
    PARTIAL) partial=1 ;;
    *)       fail=1 ;;
  esac
  node -e "
const entry={
  spec: process.argv[2],
  versionId: process.argv[3],
  verdict: process.argv[4],
  expectedOps: parseInt(process.argv[5]||'0',10),
  actualMethods: process.argv[6] ? parseInt(process.argv[6],10) : null
};
if (process.argv[7]) entry.failStage=process.argv[7];
if (process.argv[8]) entry.failDetail=process.argv[8];
console.log(JSON.stringify({
  timestamp: process.argv[1],
  aborted: false,
  summary: { total:1, pass:parseInt(process.argv[9],10), partial:parseInt(process.argv[10],10), fail:parseInt(process.argv[11],10) },
  results: [entry]
}, null, 2));
" -- "$timestamp" "$spec_path" "$SPEC_VERSION_ID" "$SPEC_VERDICT" \
  "$SPEC_EXPECTED_OPS" "${SPEC_ACTUAL_METHODS:-}" "${SPEC_FAIL_STAGE:-}" "${SPEC_FAIL_DETAIL:-}" \
  "$pass" "$partial" "$fail" > "$REPORT_FILE"
  echo ""
  echo "Report written to $REPORT_FILE"
  write_report_md

  [ "$SPEC_VERDICT" = "PASS" ] && exit 0 || exit 1
}

#Fetch command, pulls spec paths from local git repo and branch specified in config
#Puts paths into validate-paths to be validated by the validate-bulk command
cmd_fetch() {
  local branch_override=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --branch) branch_override="${2:-}"; shift 2 ;;
      -h|--help) usage ;;
      -*) echo "Unknown flag: $1" >&2; usage ;;
      *)  echo "Unknown arg: $1" >&2; usage ;;
    esac
  done
  local branch="${branch_override:-$ASSETS_BRANCH}"

  mkdir -p "$(dirname "$ASSETS_CACHE_DIR")"

  if [ -d "$ASSETS_CACHE_DIR/.git" ]; then
    echo "Updating asset cache at $ASSETS_CACHE_DIR (branch $branch)..." >&2
    git -C "$ASSETS_CACHE_DIR" fetch --depth 1 origin "$branch" >/dev/null 2>&1 || {
      echo "git fetch failed; check network or repo access" >&2; exit 2;
    }
    git -C "$ASSETS_CACHE_DIR" checkout -B "$branch" "origin/$branch" >/dev/null 2>&1 || {
      echo "git checkout $branch failed" >&2; exit 2;
    }
  else
    echo "Cloning $ASSETS_REPO_URL (branch $branch) to $ASSETS_CACHE_DIR..." >&2
    git clone --depth 1 --branch "$branch" "$ASSETS_REPO_URL" "$ASSETS_CACHE_DIR" >/dev/null 2>&1 || {
      echo "git clone failed; check network or repo access" >&2; exit 2;
    }
  fi

  local search_root
  if [ -d "$ASSETS_CACHE_DIR/assets" ]; then
    search_root="$ASSETS_CACHE_DIR/assets"
  else
    search_root="$ASSETS_CACHE_DIR"
  fi

  local paths_json
  paths_json=$(find "$search_root" -type f -name '*.json' -path '*/OpenAPIs/*' 2>/dev/null | sort | node -e "
const lines=require('fs').readFileSync(0,'utf-8').trim().split('\n').filter(Boolean);
console.log(JSON.stringify(lines, null, 2));
")

  local count
  count=$(echo "$paths_json" | node -e "console.log(JSON.parse(require('fs').readFileSync(0,'utf-8')).length)")

  echo "$paths_json" > "$PATHS_FILE"
  echo "Found $count spec(s). Paths written to $PATHS_FILE."
}

#Bulk validation, pulls from validate-paths.json populated by the fetch request
cmd_bulk() {
  # Bulk defaults to cleanup=true
  local cleanup=true group_override="" throttle="0"
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-cleanup) cleanup=false; shift ;;
      --cleanup)    cleanup=true; shift ;;
      --throttle)   throttle="${2:-1}"; shift 2 ;;
      --group)      group_override="${2:-}"; shift 2 ;;
      -h|--help)    usage ;;
      *)            echo "Unknown bulk arg: $1" >&2; usage ;;
    esac
  done
  GROUP_NAME="${group_override:-$DEFAULT_GROUP}"
  CLEANUP="$cleanup"

  if [ ! -f "$PATHS_FILE" ]; then
    echo "No paths file found at $PATHS_FILE. Run 'validate-integration fetch' first." >&2
    exit 2
  fi

  local paths_array
  paths_array=$(cat "$PATHS_FILE")
  local n_total
  n_total=$(echo "$paths_array" | node -e "console.log(JSON.parse(require('fs').readFileSync(0,'utf-8')).length)")

  if [ "$n_total" -eq 0 ]; then
    echo "No specs in paths file." >&2
    exit 0
  fi

  if ! do_login; then
    echo "Login failed. Check IAP URL/credentials in $CONFIG_FILE." >&2
    exit 2
  fi

  echo "Running $n_total spec(s) against $IAP_URL..."
  echo ""

  local pass_count=0 partial_count=0 fail_count=0
  local results_json="[]"
  local iter=0
  local mark="" summary="" label=""

  while IFS= read -r spec_path; do
    [ -z "$spec_path" ] && continue
    if [ "$iter" -gt 0 ]; then
      sleep "$throttle"
      if ! platform_health "$LOGIN_TOKEN"; then
        echo ""
        echo "=== Bulk aborted ==="
        echo "Platform health check failed before next spec (sanity ping != HTTP 200)."
        echo "Progress so far:  PASS=$pass_count PARTIAL=$partial_count FAIL=$fail_count"
        echo ""
        echo "Try:   validate-integration platform-reset"
        echo "Then:  validate-integration bulk"
        local aborted_ts aborted_done
        aborted_ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        aborted_done=$((pass_count + partial_count + fail_count))
        node -e "
console.log(JSON.stringify({
  timestamp: process.argv[1],
  aborted: true,
  summary: {
    total:     parseInt(process.argv[2],10),
    validated: parseInt(process.argv[3],10),
    pass:      parseInt(process.argv[4],10),
    partial:   parseInt(process.argv[5],10),
    fail:      parseInt(process.argv[6],10)
  },
  results: JSON.parse(process.argv[7])
}, null, 2));
" -- "$aborted_ts" "$n_total" "$aborted_done" "$pass_count" "$partial_count" "$fail_count" "$results_json" > "$REPORT_FILE"
        echo "Partial report written to $REPORT_FILE"
        write_report_md
        exit 2
      fi
    fi
    iter=$((iter + 1))

    validate_one_spec "$spec_path" "$LOGIN_TOKEN"

    case "$SPEC_VERDICT" in
      PASS)    pass_count=$((pass_count+1)) ;;
      PARTIAL) partial_count=$((partial_count+1)) ;;
      *)       fail_count=$((fail_count+1)) ;;
    esac

    mark=$(verdict_mark "$SPEC_VERDICT")
    case "$SPEC_VERDICT" in
      PASS)    summary="PASS ($SPEC_ACTUAL_METHODS/$SPEC_EXPECTED_OPS)" ;;
      PARTIAL) summary="PARTIAL ($SPEC_ACTUAL_METHODS/$SPEC_EXPECTED_OPS)" ;;
      *)       summary="FAIL @${SPEC_FAIL_STAGE}: ${SPEC_FAIL_DETAIL}" ;;
    esac

    label=$(echo "$spec_path" | node -e "
const p=require('fs').readFileSync(0,'utf-8').trim();
const parts=p.split('/');
const idx=parts.lastIndexOf('OpenAPIs');
if(idx>=1) process.stdout.write(parts.slice(idx-1).join('/'));
else process.stdout.write(parts.slice(-2).join('/'));
")
    printf '  [%s] %-50s %s\n' "$mark" "$label" "$summary"

    results_json=$(node -e "
const arr=JSON.parse(process.argv[1]);
const entry={
  spec: process.argv[2],
  versionId: process.argv[3],
  verdict: process.argv[4],
  expectedOps: parseInt(process.argv[5]||'0',10),
  actualMethods: process.argv[6] ? parseInt(process.argv[6],10) : null
};
if (process.argv[7]) entry.failStage=process.argv[7];
if (process.argv[8]) entry.failDetail=process.argv[8];
arr.push(entry);
console.log(JSON.stringify(arr));
" -- "$results_json" "$spec_path" "$SPEC_VERSION_ID" "$SPEC_VERDICT" \
  "$SPEC_EXPECTED_OPS" "${SPEC_ACTUAL_METHODS:-}" "${SPEC_FAIL_STAGE:-}" "${SPEC_FAIL_DETAIL:-}")

  done < <(echo "$paths_array" | node -e "
const paths=JSON.parse(require('fs').readFileSync(0,'utf-8'));
console.log(paths.join('\n'));
")

  echo ""
  echo "=== Bulk Summary ==="
  echo "Total:    $n_total"
  echo "PASS:     $pass_count"
  echo "PARTIAL:  $partial_count"
  echo "FAIL:     $fail_count"

  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  node -e "
console.log(JSON.stringify({
  timestamp: process.argv[1],
  aborted: false,
  summary: {
    total:   parseInt(process.argv[2],10),
    pass:    parseInt(process.argv[3],10),
    partial: parseInt(process.argv[4],10),
    fail:    parseInt(process.argv[5],10)
  },
  results: JSON.parse(process.argv[6])
}, null, 2));
" -- "$timestamp" "$n_total" "$pass_count" "$partial_count" "$fail_count" "$results_json" > "$REPORT_FILE"

  echo ""
  echo "Report written to $REPORT_FILE"
  write_report_md

  if [ "$fail_count" -gt 0 ] || [ "$partial_count" -gt 0 ]; then
    exit 1
  fi
  exit 0
}

# Restart the platform container to clear in-memory bloat that may build up after
# many bulk runs.
# Data in mongo/redis is untouched, only the platform's Node process is recycled.
cmd_platform_reset() {
  case "${1:-}" in
    -h|--help) usage ;;
    "") ;;
    *) echo "Unknown platform-reset arg: $1" >&2; usage ;;
  esac

  if ! command -v docker >/dev/null 2>&1; then
    echo "platform-reset: 'docker' not found on PATH." >&2
    echo "  If your IAP runs elsewhere, restart the platform process by whatever" >&2
    echo "  means your setup uses (systemd, pm2, etc.)." >&2
    exit 2
  fi

  if ! docker inspect "$PLATFORM_CONTAINER" >/dev/null 2>&1; then
    echo "platform-reset: container '$PLATFORM_CONTAINER' not found." >&2
    echo "  Edit 'platform_container' in $CONFIG_FILE if your container name differs." >&2
    exit 2
  fi

  echo "Restarting container '$PLATFORM_CONTAINER'..."
  if ! docker restart "$PLATFORM_CONTAINER" >/dev/null 2>&1; then
    echo "platform-reset: 'docker restart $PLATFORM_CONTAINER' failed." >&2
    exit 2
  fi

  printf "Waiting for the platform to become healthy"
  local elapsed=0 max=120 code
  while [ "$elapsed" -lt "$max" ]; do
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 -X POST "$IAP_URL/login" \
      -H "Content-Type: application/json" \
      -d "{\"user\": {\"username\": \"$USERNAME\", \"password\": \"$PASSWORD\"}}" 2>/dev/null)
    if [ "$code" = "200" ]; then
      echo ""
      echo "Platform healthy after ${elapsed}s."
      return 0
    fi
    printf "."
    sleep 2
    elapsed=$((elapsed + 2))
  done
  echo ""
  echo "platform-reset: platform did not become healthy within ${max}s." >&2
  echo "  Check 'docker logs $PLATFORM_CONTAINER' for startup errors." >&2
  exit 2
}

# --------- dispatch ---------
SUB="${1:-}"
case "$SUB" in
  fetch)          shift; cmd_fetch "$@" ;;
  bulk)           shift; cmd_bulk "$@" ;;
  platform-reset) shift; cmd_platform_reset "$@" ;;
  help|-h|--help) print_help; exit 0 ;;
  "")             usage ;;
  *)              cmd_single "$@" ;;
esac
